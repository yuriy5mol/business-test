# --- PostgreSQL Configuration ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=crm_db

# --- Backend Configuration ---
# DATABASE_URL: internal URL for the backend container to talk to the DB container
DATABASE_URL=postgresql://admin:your_secure_password@postgres-db:5432/crm_db

# JWT_SECRET_KEY: Use a long random string (e.g., openssl rand -hex 32)
JWT_SECRET_KEY=your_random_hex_key_here

# --- pgAdmin (Optional/Local) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin_password

# --- Deployment / Docker Configuration ---
DOCKER_API_VERSION=1.54
